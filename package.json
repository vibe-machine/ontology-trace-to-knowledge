{
  "name": "trace-to-knowledge",
  "displayName": "Trace-to-Knowledge",
  "version": "1.0.1",
  "description": "Trace-to-Knowledge (T2K): high-signal ontology for distilling raw traces into reusable knowledge.",
  "author": "vibe-machine",
  "license": "MIT",
  "source": "https://github.com/vibe-machine/ontology-trace-to-knowledge",
  "prefix": "t2k",
  "schemas": [
    {
      "name": "traceToKnowledge",
      "file": "schema/traceToKnowledge.tql"
    }
  ],
  "data": [
    "data/trace-to-knowledge-provenance.tql",
    "data/trace-to-knowledge-schema-docs.tql"
  ],
  "dependencies": [
    {
      "name": "gist",
      "version": ">=14.0.0"
    }
  ],
  "scripts": {
    "refresh:package-contract": "node tools/package_contract/refresh_package_contract.mjs",
    "validate:bootstrap": "node tools/package_contract/validate_bootstrap.mjs",
    "test:typedb-bootstrap": "node tools/package_contract/validate_typedb_bootstrap.mjs",
    "test": "npm run validate:bootstrap && npm run test:typedb-bootstrap"
  },
  "manifests": [
    "manifests/trace-to-knowledge-v1.0.1.package-manifest.json"
  ],
  "assembly": {
    "loadOrder": [
      "schema/traceToKnowledge.tql",
      "data/trace-to-knowledge-provenance.tql",
      "data/trace-to-knowledge-schema-docs.tql"
    ],
    "generatedArtifacts": [
      "data/trace-to-knowledge-schema-docs.tql",
      "data/trace-to-knowledge-provenance.tql",
      "manifests/package-manifest.schema.json",
      "manifests/trace-to-knowledge-v1.0.1.package-manifest.json"
    ]
  },
  "provenance": {
    "manifest": "manifests/trace-to-knowledge-v1.0.1.package-manifest.json",
    "status": "bootstrap"
  }
}
